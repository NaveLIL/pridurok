# ====== Discord ======
# Токен бота из https://discord.com/developers/applications
# ВАЖНО: НИКОГДА не коммитить и не публиковать!
DISCORD_TOKEN=PASTE_NEW_TOKEN_HERE

# ID сервера для мгновенной регистрации slash-команд (опционально, ускоряет sync)
# Правый клик по серверу → "Копировать ID сервера" (нужен Developer Mode)
DISCORD_GUILD_ID=

# ====== LM Studio ======
# По умолчанию LM Studio поднимает OpenAI-совместимый сервер на :1234
LMSTUDIO_BASE_URL=http://localhost:1234/v1
LMSTUDIO_API_KEY=lm-studio
# Имя модели как оно отображается в LM Studio (вкладка Local Server → Model)
# Примеры: "openai/gpt-oss-20b", "qwen2.5-14b-instruct"
LMSTUDIO_MODEL=openai/gpt-oss-20b

# ====== Поведение бота ======
# Каналы где бот отвечает на ВСЁ (через запятую, ID каналов).
# В остальных каналах — только по @упоминанию.
ACTIVE_CHANNELS=

# Роли которым разрешено вызывать бота (через запятую, ID ролей).
# Пусто = разрешено всем.
ALLOWED_ROLES=

# Сколько последних сообщений хранить в контексте на пользователя
HISTORY_LIMIT=20

# Максимум токенов в ответе
MAX_TOKENS=600

# Температура (креативность) 0.0 - 2.0
TEMPERATURE=0.9

# Минимальный интервал (сек) между правками сообщения при стриминге
STREAM_EDIT_INTERVAL=1.2

# Летопись чата: если указать канал, бот будет раз в неделю постить сводку
CHRONICLE_CHANNEL=
CHRONICLE_INTERVAL_HOURS=24
CHRONICLE_LOOKBACK_DAYS=7
