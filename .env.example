# ====== ОБЯЗАТЕЛЬНО ======
DISCORD_TOKEN=PASTE_YOUR_TOKEN_HERE
# ID сервера (для быстрой синхронизации slash-команд). Оставь пустым для глобальной синхронизации.
DISCORD_GUILD_ID=

# ====== LM STUDIO ======
LMSTUDIO_BASE_URL=http://localhost:1234/v1
LMSTUDIO_API_KEY=lm-studio
LMSTUDIO_MODEL=openai/gpt-oss-20b

# ====== КАНАЛЫ ======
# ID каналов через запятую, где бот отвечает на все сообщения
ACTIVE_CHANNELS=123456789,987654321
# ID ролей через запятую — только эти роли могут общаться с ботом (пусто = все)
ALLOWED_ROLES=

# ====== ПОВЕДЕНИЕ ======
HISTORY_LIMIT=40
MAX_TOKENS=900
TEMPERATURE=0.65
STREAM_EDIT_INTERVAL=1.2

# ====== АНТИСПАМ ======
USER_COOLDOWN=8
MAX_QUEUE_SIZE=10
MAX_PROMPT_LEN=500
FLOOD_LIMIT_PER_HOUR=30

# ====== АВТОПИНГ ======
# ID канала для пинга рандомного юзера (пусто = выкл)
RANDOM_PING_CHANNEL=
# ID роли из которой выбирать жертву (пусто = все)
RANDOM_PING_ROLE=
RANDOM_PING_INTERVAL_HOURS=12

# ====== ВБРОСЫ ======
# ID канала для случайных вбросов (пусто = выкл)
BLURT_CHANNEL=
BLURT_INTERVAL_MIN_HOURS=2
BLURT_INTERVAL_MAX_HOURS=5
# Молчать если в канале писали менее N минут назад
BLURT_QUIET_MINUTES=30

# ====== РИТУАЛЫ ======
# ID канала для утреннего/ночного приветствия (пусто = выкл)
RITUAL_CHANNEL=
RITUAL_MORNING_HOUR=9
RITUAL_NIGHT_HOUR=0

# ====== ДОПОЛНИТЕЛЬНО ======
CHANNEL_CONTEXT_LIMIT=6
MENTION_REACT_CHANCE=0.3
SPAR_DURATION_MINUTES=10
EMOJI_REACT_CHANCE=0.25
GROUP_DEBOUNCE_SECONDS=6
CHANNEL_BUSY_THRESHOLD=15
HEALTH_CHECK_INTERVAL=120
AUTO_FACTS_CHANCE=0.5
# Город для погодных вбросов (используется wttr.in, без API-ключа)
# Примеры: Moscow, Novosibirsk, Saint-Petersburg, Yekaterinburg
WEATHER_CITY=Moscow
